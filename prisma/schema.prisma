generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 1. Companies
model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  requireApprovalForNewAgents Boolean @default(false)

  agents         Agent[]
  projects       Project[]
  budgetPolicies BudgetPolicy[]
  costEvents     CostEvent[]
  activityLogs   ActivityLog[]
  skills         Skill[]
  memoryEntries  MemoryEntry[]
  configEntries  ConfigEntry[]
  queueJobs      QueueJob[]
  heartbeatRuns  HeartbeatRun[]
  scheduledJobs  ScheduledJob[]
  goals          Goal[]
  secrets        CompanySecret[]
  approvals      Approval[]
  labels         Label[]
  pipelineRuns   PipelineRun[]

  @@map("companies")
}

// 2. Projects
model Project {
  id         String  @id @default(cuid())
  companyId  String
  name       String
  path       String
  stack      String  @default("other")
  config     String  @default("{}")
  readmePath String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sprints Sprint[]
  issues  Issue[]
  pipelineRuns PipelineRun[]

  @@unique([companyId, name])
  @@map("projects")
}

// 3. Agents
model Agent {
  id            String  @id @default(cuid())
  companyId     String
  slug          String
  name          String
  role          String
  modelProvider String  @default("claude-cli")
  model         String
  promptFile    String?
  reportsTo     String?
  status        String  @default("idle")
  permissions   String  @default("{}")
  adapterConfig String  @default("{}")
  clientConfig  String  @default("{}")
  maxConcurrent Int     @default(1)
  heartbeatCron String?
  maxSessionRuns   Int @default(20)
  maxSessionTokens Int @default(100000)
  maxSessionAgeHours Int @default(24)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  apiKeys     AgentApiKey[]
  costEvents  CostEvent[]
  assignedIssues Issue[]   @relation("AssignedAgent")
  runtimeState AgentRuntimeState?
  revisions    AgentConfigRevision[]

  @@unique([companyId, slug])
  @@map("agents")
}

// 4. Agent API Keys
model AgentApiKey {
  id        String    @id @default(cuid())
  agentId   String
  keyHash   String    @unique
  prefix    String
  lastUsed  DateTime?
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_api_keys")
}

// 5. Issues
model Issue {
  id              String  @id @default(cuid())
  projectId       String
  sprintId        String?
  title           String
  description     String?
  type            String  @default("feature")
  status          String  @default("open")
  priority        String  @default("normal")
  assignedAgentId String?
  parentIssueId   String?
  goalId          String?
  result          String?
  metadata        String  @default("{}")
  executionLockedAt DateTime?
  executionAgentSlug String?
  executionJobId     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint        Sprint?  @relation(fields: [sprintId], references: [id])
  assignedAgent Agent?   @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  parentIssue   Issue?   @relation("SubIssues", fields: [parentIssueId], references: [id])
  goal          Goal?    @relation(fields: [goalId], references: [id])
  subIssues     Issue[]  @relation("SubIssues")

  skillExecutions SkillExecution[]
  queueJobs       QueueJob[]
  executionWorkspace ExecutionWorkspace?
  comments           IssueComment[]
  workProducts       IssueWorkProduct[]
  issueLabels        IssueLabel[]
  pipelineRuns       PipelineRun[]

  @@map("issues")
}

model PipelineRun {
  id                String   @id @default(cuid())
  companyId         String
  projectId         String?
  issueId           String?
  source            String
  requestType       String
  status            String   @default("pending")
  requestedBy       String
  requestedAgentSlug String?
  entryAgentSlug    String
  currentStepKey    String?
  clientRequestKey  String?
  planJson          String   @default("{}")
  lastError         String?
  createdAt         DateTime @default(now())
  startedAt         DateTime @default(now())
  completedAt       DateTime?
  updatedAt         DateTime @updatedAt

  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project      Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  issue        Issue?           @relation(fields: [issueId], references: [id], onDelete: SetNull)
  stepRuns     PipelineStepRun[]
  workProducts IssueWorkProduct[]
  sprintRuns   SprintRun[]

  @@unique([companyId, clientRequestKey])
  @@index([companyId, status])
  @@index([issueId])
  @@map("pipeline_runs")
}

model PipelineStepRun {
  id            String   @id @default(cuid())
  pipelineRunId String
  stepKey       String
  agentSlug     String
  status        String   @default("pending")
  inputSnapshot String
  dependsOn     String   @default("[]")
  queueJobId    String?  @unique
  attempts      Int      @default(0)
  resultSummary String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  pipelineRun  PipelineRun        @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)
  workProducts IssueWorkProduct[]
  logs         PipelineStepLog[]

  @@unique([pipelineRunId, stepKey])
  @@index([pipelineRunId, status])
  @@index([queueJobId])
  @@map("pipeline_step_runs")
}

model PipelineStepLog {
  id                String   @id @default(cuid())
  pipelineStepRunId String
  chunkIndex        Int
  text              String
  createdAt         DateTime @default(now())

  pipelineStepRun PipelineStepRun @relation(fields: [pipelineStepRunId], references: [id], onDelete: Cascade)

  @@unique([pipelineStepRunId, chunkIndex])
  @@index([pipelineStepRunId, chunkIndex])
  @@map("pipeline_step_logs")
}

// 6. Sprints
model Sprint {
  id        String    @id @default(cuid())
  projectId String
  number    Int
  goal      String
  status    String    @default("planning")
  startedAt DateTime?
  closedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues  Issue[]

  @@unique([projectId, number])
  @@map("sprints")
}

// 7. Cost Events
model CostEvent {
  id           String   @id @default(cuid())
  companyId    String
  agentId      String
  issueId      String?
  model        String
  provider     String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  costUsd      Float    @default(0)
  durationMs   Int      @default(0)
  createdAt    DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agent   Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([agentId, createdAt])
  @@map("cost_events")
}

// 8. Budget Policies
model BudgetPolicy {
  id              String  @id @default(cuid())
  companyId       String
  scope           String  @default("company")
  scopeId         String?
  monthlyLimitUsd Float
  softLimitPct    Int     @default(80)
  hardLimitPct    Int     @default(100)
  action          String  @default("warn")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, scope, scopeId])
  @@map("budget_policies")
}

// 9. Skills
model Skill {
  id          String  @id @default(cuid())
  companyId   String
  name        String
  description String
  content     String
  version     Int     @default(1)
  active      Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company    Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  executions SkillExecution[]

  @@unique([companyId, name])
  @@map("skills")
}

// 10. Skill Executions
model SkillExecution {
  id           String  @id @default(cuid())
  skillId      String
  issueId      String
  result       String  @default("failed")
  errorMessage String?
  durationMs   Int     @default(0)
  createdAt    DateTime @default(now())

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)
  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@map("skill_executions")
}

// 11. Memory Entries
model MemoryEntry {
  id        String   @id @default(cuid())
  companyId String
  type      String   @default("learning")
  content   String
  source    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, type])
  @@map("memory_entries")
}

// 12. Activity Log
model ActivityLog {
  id        String   @id @default(cuid())
  companyId String
  actor     String
  action    String
  resource  String?
  metadata  String   @default("{}")
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@map("activity_logs")
}

// 13. Queue Jobs (SQLite polling)
model QueueJob {
  id          String    @id @default(cuid())
  companyId   String
  agentSlug   String
  issueId     String?
  type        String    @default("agent_task")
  payload     String    @default("{}")
  status      String    @default("pending")
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  result      String?
  error       String?
  scheduledAt DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  queuedAt    DateTime  @default(now())
  workerId    String?
  leaseExpiresAt DateTime?
  lastHeartbeatAt DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  issue   Issue?  @relation(fields: [issueId], references: [id])

  @@index([status, scheduledAt])
  @@index([companyId, status])
  @@map("queue_jobs")
}

// 14. Heartbeat Runs
model HeartbeatRun {
  id          String    @id @default(cuid())
  agentSlug   String
  companyId   String
  status      String    @default("triggered")
  result      String?
  triggeredAt DateTime  @default(now())
  completedAt DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, agentSlug])
  @@map("heartbeat_runs")
}

// 15. Config Store
model ConfigEntry {
  id        String  @id @default(cuid())
  companyId String?
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, key])
  @@map("config_entries")
}

// 16. Scheduled Jobs
model ScheduledJob {
  id             String    @id @default(cuid())
  jobKey         String    @unique
  companyId      String
  agentSlug      String
  cronExpression String
  nextRunAt      DateTime
  lastRunAt      DateTime?
  enabled        Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([enabled, nextRunAt])
  @@map("scheduled_jobs")
}

// 17. Sync Outbox
model SyncOutbox {
  id            String    @id @default(cuid())
  eventType     String
  payload       String
  status        String    @default("pending")
  attempts      Int       @default(0)
  lastAttemptAt DateTime?
  sentAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([status, createdAt])
  @@map("sync_outbox")
}

// 18. Goals
model Goal {
  id             String  @id @default(cuid())
  companyId      String
  title          String
  description    String?
  level          String  @default("task")   // company | team | agent | task
  status         String  @default("active") // active | completed | frozen
  parentId       String?
  ownerAgentSlug String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company      Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent       Goal?   @relation("GoalHierarchy", fields: [parentId], references: [id])
  children     Goal[]  @relation("GoalHierarchy")
  linkedIssues Issue[]

  @@index([companyId, level])
  @@map("goals")
}

// 19. Execution Workspaces
model ExecutionWorkspace {
  id            String    @id @default(cuid())
  issueId       String    @unique
  agentSlug     String
  policy        String    @default("shared")  // shared | per_task | git_worktree
  workspacePath String
  branchName    String?
  status        String    @default("active")  // active | completed | cleaned
  createdAt     DateTime  @default(now())
  cleanedAt     DateTime?

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  @@map("execution_workspaces")
}

// 20. Agent Session Persistence
model AgentRuntimeState {
  id          String   @id @default(cuid())
  agentId     String   @unique
  sessionId   String?
  tokenCount  Int      @default(0)
  runCount    Int      @default(0)
  lastUsedAt  DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  @@map("agent_runtime_state")
}

model AgentTaskSession {
  id         String    @id @default(cuid())
  agentId    String
  issueId    String
  sessionId  String
  tokenCount Int       @default(0)
  createdAt  DateTime  @default(now())
  closedAt   DateTime?

  @@unique([agentId, issueId])
  @@map("agent_task_sessions")
}

model AgentConfigRevision {
  id         String   @id @default(cuid())
  agentId    String
  revision   Int
  config     String   // JSON snapshot
  changeNote String?
  createdAt  DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, revision])
  @@map("agent_config_revisions")
}

// 21. Company Secrets
model CompanySecret {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?
  value       String   // AES-256 encrypted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@map("company_secrets")
}

model Approval {
  id          String   @id @default(cuid())
  companyId   String
  type        String   // hire_agent | budget_override | ceo_strategy
  status      String   @default("pending")  // pending | approved | rejected | cancelled
  requestedBy String   // agent slug veya "user"
  metadata    String   @default("{}")  // JSON — bağlam bilgisi
  requestedAt DateTime @default(now())
  reviewedAt  DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  @@map("approvals")
}

model IssueComment {
  id        String   @id @default(cuid())
  issueId   String
  authorSlug String  // agent slug veya "user"
  content   String
  createdAt DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  @@map("issue_comments")
}

model IssueWorkProduct {
  id                String   @id @default(cuid())
  issueId           String
  agentSlug         String
  type              String   // code | doc | test | pr | analysis
  title             String
  content           String
  filePath          String?
  pipelineRunId     String?
  pipelineStepRunId String?
  artifactType      String?  // code_block | execution_summary | ProductSpec | SprintContract | BuildResult | EvaluationReport
  structuredPayload String?  // JSON — typed artifact payload validated against ARTIFACT_SCHEMAS[artifactType]
  schemaVersion     String?  // artifact schema version tag (e.g. "v2.1")
  createdAt         DateTime @default(now())

  issue           Issue            @relation(fields: [issueId], references: [id], onDelete: Cascade)
  pipelineRun     PipelineRun?     @relation(fields: [pipelineRunId], references: [id], onDelete: SetNull)
  pipelineStepRun PipelineStepRun? @relation(fields: [pipelineStepRunId], references: [id], onDelete: SetNull)

  @@index([pipelineRunId])
  @@index([artifactType])
  @@map("issue_work_products")
}

// V2.1 – Sprint execution ledger: one row per sprint per pipeline run.
// Tracks the full lifecycle of a sprint: contracting → building → passed / approval_pending / failed.
// The harness reads this to determine where a pipeline is in its sprint loop.
model SprintRun {
  id                   String    @id @default(cuid())
  pipelineRunId        String
  sprintNumber         Int
  status               String    @default("contracting") // contracting | building | passed | failed | approval_pending
  approvalReason       String?   // human_review_required | not_verifiable_required_machine | build_retry_limit | contract_revision_limit | evaluation_failure
  contractRevisions    Int       @default(0)
  buildAttempts        Int       @default(0)
  contractArtifactId   String?   // IssueWorkProduct.id of the approved SprintContract artifact
  buildArtifactId      String?   // IssueWorkProduct.id of the BuildResult artifact
  evaluationArtifactId String?   // IssueWorkProduct.id of the final EvaluationReport artifact
  createdAt            DateTime  @default(now())
  completedAt          DateTime?

  pipelineRun PipelineRun @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)

  @@unique([pipelineRunId, sprintNumber])
  @@index([pipelineRunId, status])
  @@map("sprint_runs")
}

model Label {
  id        String @id @default(cuid())
  companyId String
  name      String
  color     String @default("#6b7280")

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  issueLabels IssueLabel[]

  @@unique([companyId, name])
  @@map("labels")
}

model IssueLabel {
  issueId String
  labelId String

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([issueId, labelId])
  @@map("issue_labels")
}
