# Forge — Environment Variables
# cp .env.example .env  →  edit as needed

# HTTP server port (default: 3131)
# FORGE_PORT=3131

# Worker concurrency — max parallel agent jobs (default: 3)
# FORGE_CONCURRENCY=3

# Claude CLI binary path (only needed if `claude` is not on your PATH)
# CLAUDE_CLI_PATH=/usr/local/bin/claude

# Logging (debug | info | warn | error)
LOG_LEVEL=info
