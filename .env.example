# Forge v3 — Environment Variables
# cp .env.example .env  →  edit as needed

# PostgreSQL (docker-compose default)
DATABASE_URL=postgresql://forge:forge@localhost:5432/forge

# Redis (docker-compose default)
REDIS_URL=redis://localhost:6379

# HTTP server
FIRM_PORT=3131

# Claude CLI binary path on your host
CLAUDE_CLI_PATH=~/.local/bin/claude

# Absolute path to the project you want agents to work on
PROJECT_PATH=.

# Logging
LOG_LEVEL=info
