{
  "name": "forge-agency",
  "version": "3.0.0",
  "description": "CLI-first AI agent orchestration platform — spawn and manage a team of AI agents from your terminal",
  "type": "module",
  "bin": {
    "forge": "./dist/bin/forge.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "dev": "tsx bin/the-firm.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/bin/the-firm.js",
    "test": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "lint": "tsc --noEmit",
    "webui:dev": "npm run dev --prefix webui",
    "webui:build": "npm run build --prefix webui",
    "webui:preview": "npm run preview --prefix webui"
  },
  "keywords": [
    "ai",
    "agent",
    "orchestration",
    "claude",
    "cli"
  ],
  "author": "The Firm",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/static": "^7.0.4",
    "@prisma/client": "^5.7.1",
    "bullmq": "^5.3.3",
    "commander": "^13.1.0",
    "crypto-random-string": "^5.0.0",
    "dotenv": "^17.3.1",
    "fastify": "^4.29.1",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.8",
    "ioredis": "^5.3.2",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prisma": "^5.7.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
