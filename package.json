{
  "name": "forge-agency",
  "version": "3.0.0",
  "description": "CLI-first AI agent orchestration platform — spawn and manage a team of AI agents from your terminal",
  "type": "module",
  "bin": {
    "forge": "./dist/bin/forge.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "dev": "tsx bin/the-firm.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/bin/the-firm.js",
    "test": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "lint": "tsc --noEmit"
  },
  "keywords": ["ai", "agent", "orchestration", "claude", "cli"],
  "author": "The Firm",
  "license": "MIT",
  "dependencies": {
    "fastify": "^4.26.2",
    "@fastify/cors": "^9.0.1",
    "bullmq": "^5.3.3",
    "ioredis": "^5.3.2",
    "@prisma/client": "^5.7.1",
    "commander": "^13.1.0",
    "@clack/prompts": "^0.10.0",
    "gray-matter": "^4.0.3",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "handlebars": "^4.7.8",
    "crypto-random-string": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "prisma": "^5.7.1",
    "tsx": "^4.7.0",
    "vitest": "^3.0.0",
    "@types/node": "^20.11.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
